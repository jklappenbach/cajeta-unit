package dev.cajeta.unit;

import cajeta.lang.Int64;

/**
 * Factory for {@Link Matcher}s — the AoT counterpart of Mockito's static matcher
 * methods (`any()`, `eq(...)`, `argThat(...)`).
 *
 * ```cajeta
 * Matcher[] expected = { ArgMatchers.eqInt(1999) };
 * MockVerify.on(gateway.engine, "charge").withArgs(#expected).times(1);
 * ```
 *
 * `eq(...)` compares by `Object` equality, which dispatches the **value-based**
 * `hash()` of box types (`Int64`, `String`, …) — so `eqInt(1999)` matches any
 * boxed `1999`, not just one identical instance. `eq(...)` takes ownership of its
 * expected value (`#`); the convenience overloads (`eqInt`) box for you.
 *
 * The concrete `Matcher` subclasses this returns are defined in {@Link Matcher}'s
 * file (after the base class) — see the note there on file parse order and
 * vtable correctness for stored matcher references.
 */
public final class ArgMatchers {

    /** Matches any argument, including null. Mockito's `any()`. */
    public static #Matcher any() {
        return heap AnyMatcher();
    }

    /** Matches an argument equal (value-based) to `expected`. Owns `expected`. */
    public static #Matcher eq(#Object expected) {
        return heap EqMatcher(#expected);
    }

    /** Convenience: `eq` for a 64-bit integer argument (boxes for you). */
    public static #Matcher eqInt(int64 value) {
        return heap EqMatcher(#Int64.of(value));
    }

    /** Matches only a null argument. Mockito's `isNull()`. */
    public static #Matcher isNull() {
        return heap NullMatcher(true);
    }

    /** Matches only a non-null argument. Mockito's `notNull()`. */
    public static #Matcher notNull() {
        return heap NullMatcher(false);
    }

    /** Matches when `pred` accepts the (boxed) argument. Mockito's `argThat(...)`. */
    public static #Matcher argThat((Object) -> boolean pred) {
        return heap PredMatcher(pred);
    }
}
