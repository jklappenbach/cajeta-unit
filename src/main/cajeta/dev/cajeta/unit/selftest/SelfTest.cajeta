package dev.cajeta.unit.selftest;

import dev.cajeta.unit.Assert;
import dev.cajeta.unit.AssertionFailure;
import dev.cajeta.unit.TestRunner;
import dev.cajeta.unit.Runner;
import dev.cajeta.unit.CallLog;
import dev.cajeta.unit.Verify;
import dev.cajeta.unit.ArgMatchers;
import dev.cajeta.unit.MockEngine;
import dev.cajeta.unit.Invocation;
import dev.cajeta.unit.Mock;
import dev.cajeta.unit.MockVerify;
import dev.cajeta.unit.Matcher;
import dev.cajeta.unit.selftest.inject.Service;
import dev.cajeta.unit.selftest.doubles.Coin;
import cajeta.lang.Int64;
import cajeta.error.RecoverableException;

/**
 * cajeta-unit's own test suite — the framework, tested with itself.
 *
 * A test framework has a bootstrap problem: you can't trust it to test itself
 * until you've proven, from first principles, that its assertion engine detects
 * BOTH a passing check (does not throw) AND a failing check (does throw). A
 * broken `isEqualTo` that always "passes" would make every self-test green and
 * hide the bug. So `bootstrap()` verifies both paths with raw try/catch — no
 * `TestRunner` — and only then do we use the (now-trusted) engine to test the
 * rest of the framework.
 *
 * Entry: `dev.cajeta.unit.selftest.SelfTest.run` (returns 0 = all green).
 */
public class SelfTest {

    /** Prove the engine's pass AND fail paths from first principles. */
    static int32 bootstrap() {
        int32 problems = 0;

        // (1) a passing check must NOT throw
        boolean threwOnPass = false;
        try {
            Assert.that(2).isEqualTo(2);
        } catch (Exception e) {
            threwOnPass = true;
        }
        if (threwOnPass) {
            System.stdout.println("  BOOTSTRAP FAIL: a passing check threw");
            problems = problems + 1;
        }

        // (2) a failing check MUST throw
        boolean threwOnFail = false;
        try {
            Assert.that(2).isEqualTo(3);
        } catch (Exception e) {
            threwOnFail = true;
        }
        if (!threwOnFail) {
            System.stdout.println("  BOOTSTRAP FAIL: a failing check did NOT throw");
            problems = problems + 1;
        }

        // (3) fail() must throw
        boolean failThrew = false;
        try {
            Assert.fail("deliberate");
        } catch (Exception e) {
            failThrew = true;
        }
        if (!failThrew) {
            System.stdout.println("  BOOTSTRAP FAIL: fail() did not throw");
            problems = problems + 1;
        }

        // (4) assertThrows passes when the body throws, fails when it doesn't
        boolean sawThrowingBody = false;
        try {
            Assert.assertThrows(() -> { Assert.fail("boom"); });
            sawThrowingBody = true;
        } catch (Exception e) {
        }
        if (!sawThrowingBody) {
            System.stdout.println("  BOOTSTRAP FAIL: assertThrows rejected a throwing body");
            problems = problems + 1;
        }

        boolean rejectedNonThrowing = false;
        try {
            Assert.assertThrows(() -> { });
        } catch (Exception e) {
            rejectedNonThrowing = true;
        }
        if (!rejectedNonThrowing) {
            System.stdout.println("  BOOTSTRAP FAIL: assertThrows accepted a non-throwing body");
            problems = problems + 1;
        }

        return problems;
    }

    public static int32 run() {
        System.stdout.println("== cajeta-unit bootstrap (verify the engine's pass AND fail paths) ==");
        int32 boot = SelfTest.bootstrap();
        if (boot > 0) {
            System.stdout.println("BOOTSTRAP BROKEN — the assertion engine is untrustworthy. Aborting.");
            return 1;
        }
        System.stdout.println("  bootstrap OK — engine verified");
        System.stdout.println("");

        System.stdout.println("== cajeta-unit self-tests (the framework, tested with itself) ==");
        TestRunner t = heap TestRunner();

        t.test("int isEqualTo passes on equal", () -> {
            Assert.that(4).isEqualTo(4);
        });
        t.test("int isNotEqualTo", () -> {
            Assert.that(4).isNotEqualTo(5);
        });
        t.test("int comparisons", () -> {
            Assert.that(5).isGreaterThan(3);
            Assert.that(2).isLessThan(10);
        });
        t.test("string isEqualTo", () -> {
            Assert.that("ab").isEqualTo("ab");
        });
        t.test("string contains and startsWith", () -> {
            Assert.that("hello").contains("ell");
            Assert.that("hello").startsWith("he");
        });
        t.test("string hasLength", () -> {
            Assert.that("abc").hasLength(3);
        });
        t.test("bool isTrue and isFalse", () -> {
            Assert.isTrue(1 > 0);
            Assert.isFalse(1 > 2);
        });
        t.test("float isCloseTo within tolerance", () -> {
            Assert.thatFloat(3.14159).isCloseTo(3.14, 0.01);
        });
        t.test("assertThrows catches a throwing body", () -> {
            Assert.assertThrows(() -> { Assert.fail("expected"); });
        });

        t.test("CallLog records and counts invocations", () -> {
            CallLog log = heap CallLog();
            log.track("a");
            log.track("a");
            log.track("b");
            Assert.that(log.count("a")).isEqualTo(2);
            Assert.that(log.total()).isEqualTo(3);
            Assert.isTrue(log.received("b"));
            Assert.isFalse(log.received("c"));
        });
        t.test("Verify received / receivedTimes / neverReceived", () -> {
            CallLog log = heap CallLog();
            log.track("save");
            log.track("save");
            Verify.received(log, "save");
            Verify.receivedTimes(log, "save", 2);
            Verify.neverReceived(log, "delete");
        });

        t.test("matchers: any / eqInt / isNull / notNull / argThat", () -> {
            Assert.isTrue(ArgMatchers.any().matches(Int64.of(5)));
            Assert.isTrue(ArgMatchers.any().matches(null));
            Assert.isTrue(ArgMatchers.eqInt(1999).matches(Int64.of(1999)));
            Assert.isFalse(ArgMatchers.eqInt(1999).matches(Int64.of(2000)));
            Assert.isTrue(ArgMatchers.isNull().matches(null));
            Assert.isFalse(ArgMatchers.isNull().matches(Int64.of(1)));
            Assert.isTrue(ArgMatchers.notNull().matches(Int64.of(1)));
            Assert.isFalse(ArgMatchers.notNull().matches(null));
            Assert.isTrue(ArgMatchers.argThat((Object o) -> {
                Int64 i = (Int64) o;
                return i.value() > 10;
            }).matches(Int64.of(50)));
            Assert.isFalse(ArgMatchers.argThat((Object o) -> {
                Int64 i = (Int64) o;
                return i.value() > 10;
            }).matches(Int64.of(5)));
        });

        t.test("MockEngine records invocations and arguments", () -> {
            MockEngine eng = heap MockEngine();
            Object[] a1 = { Int64.of(1999) };
            eng.recordCall("charge", #a1);
            Object[] a2 = { Int64.of(5) };
            eng.recordCall("charge", #a2);
            Object[] a3 = { };
            eng.recordCall("refund", #a3);
            Assert.that(eng.totalCalls()).isEqualTo(3);
            Assert.that(eng.callCount("charge")).isEqualTo(2);
            Assert.that(eng.callCount("refund")).isEqualTo(1);
            Assert.that(eng.callCount("nope")).isEqualTo(0);

            Invocation first = eng.invocationAt(0);
            Assert.that(first.argCount()).isEqualTo(1);
            Int64 amt = (Int64) first.arg(0);
            Assert.that(amt.value()).isEqualTo(1999);

            Invocation refund = eng.invocationAt(2);
            Assert.that(refund.method()).isEqualTo("refund");
            Assert.that(refund.argCount()).isEqualTo(0);
        });

        t.test("stubbing: thenReturn box + user type, consecutive, matcher-selected", () -> {
            MockEngine eng = heap MockEngine();

            // any-args return of a box
            Mock.when(eng, "charge").thenReturn(#Int64.of(100));
            Object[] c1 = { Int64.of(5) };
            Assert.that(((Int64) eng.handle("charge", #c1)).value()).isEqualTo(100);

            // user-type round trip (Object answer downcast back to a user class)
            Mock.when(eng, "mint").thenReturn(#(heap Coin(25)));
            Object[] m0 = { };
            Coin coin = (Coin) eng.handle("mint", #m0);
            Assert.that(coin.cents).isEqualTo(25);

            // consecutive returns: 1, 2, then 2 repeats
            Mock.when(eng, "next").thenReturn(#Int64.of(1)).thenReturn(#Int64.of(2));
            Object[] n0 = { };
            Object[] n1 = { };
            Object[] n2 = { };
            Assert.that(((Int64) eng.handle("next", #n0)).value()).isEqualTo(1);
            Assert.that(((Int64) eng.handle("next", #n1)).value()).isEqualTo(2);
            Assert.that(((Int64) eng.handle("next", #n2)).value()).isEqualTo(2);

            // matcher-selected: distinct args route to distinct answers
            Matcher[] mm1 = { ArgMatchers.eqInt(1) };
            Matcher[] mm2 = { ArgMatchers.eqInt(2) };
            Mock.when(eng, "f").withArgs(#mm1).thenReturn(#Int64.of(10));
            Mock.when(eng, "f").withArgs(#mm2).thenReturn(#Int64.of(20));
            Object[] f1 = { Int64.of(1) };
            Object[] f2 = { Int64.of(2) };
            Assert.that(((Int64) eng.handle("f", #f1)).value()).isEqualTo(10);
            Assert.that(((Int64) eng.handle("f", #f2)).value()).isEqualTo(20);

            // unstubbed method answers null
            Object[] u0 = { };
            Assert.isTrue(eng.handle("unstubbed", #u0) == null);
        });
        t.test("stubbing: thenThrow makes the call throw", () -> {
            MockEngine eng = heap MockEngine();
            Mock.when(eng, "boom").thenThrow(#(heap RecoverableException(#("kaboom"))));
            Assert.assertThrows(() -> {
                Object[] e0 = { };
                eng.handle("boom", #e0);
            });
        });

        t.test("verification: times/once/never/atLeast/atMost with matchers", () -> {
            MockEngine eng = heap MockEngine();
            Object[] a1 = { Int64.of(1999) };
            eng.recordCall("charge", #a1);
            Object[] a2 = { Int64.of(1999) };
            eng.recordCall("charge", #a2);
            Object[] a3 = { Int64.of(5) };
            eng.recordCall("charge", #a3);
            Object[] cl = { };
            eng.recordCall("close", #cl);

            MockVerify.times(eng, "charge", 3);
            MockVerify.atLeast(eng, "charge", 2);
            MockVerify.atMost(eng, "charge", 3);
            MockVerify.once(eng, "close");
            MockVerify.never(eng, "open");
            Assert.that(MockVerify.count(eng, "charge")).isEqualTo(3);

            Matcher[] m1999 = { ArgMatchers.eqInt(1999) };
            MockVerify.timesWith(eng, "charge", #m1999, 2);
            Matcher[] m5 = { ArgMatchers.eqInt(5) };
            MockVerify.timesWith(eng, "charge", #m5, 1);
            Matcher[] mNeg = { ArgMatchers.eqInt(404) };
            MockVerify.neverWith(eng, "charge", #mNeg);

            // wrong counts fail the verification (throw)
            Assert.assertThrows(() -> {
                MockVerify.times(eng, "charge", 99);
            });
            Assert.assertThrows(() -> {
                MockVerify.atLeast(eng, "open", 1);
            });
        });

        t.skip("a deliberately skipped test", "demonstrates skip");

        int32 rc = t.summary();

        // E2E: the @Inject runtime override (needs a --profile=test build).
        System.stdout.println("");
        System.stdout.println("== @Inject override (DI context substitution) ==");
        int32 injectRc = Service.run();
        if (injectRc != 0) {
            rc = 1;
        }

        // Annotation-driven @Test discovery — the reflective Runner finds and
        // runs @Test methods (with @BeforeEach/@AfterEach/@Disabled) across the
        // binary; ExampleTest is the fixture it discovers.
        System.stdout.println("");
        System.stdout.println("== @Test discovery (annotation-driven Runner) ==");
        int32 discoveredRc = Runner.runAll();
        if (discoveredRc != 0) {
            rc = 1;
        }

        return rc;
    }
}
