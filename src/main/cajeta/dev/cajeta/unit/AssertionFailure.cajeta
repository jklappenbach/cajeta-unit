package dev.cajeta.unit;

import cajeta.error.RecoverableException;

/**
 * Thrown when an assertion does not hold. The runner catches it per test and
 * records the failure (message + which test), then continues to the next test —
 * a single failing assertion fails its test, not the whole run.
 *
 * It is a `RecoverableException` (the message-carrying, catchable branch of the
 * error model) so `assertThrows` and the runner can distinguish a deliberate
 * assertion failure from an unexpected error in the code under test.
 */
public class AssertionFailure extends RecoverableException {
    public AssertionFailure(#String message) {
        this.message = message;
        this.cause = 0;
    }
}
